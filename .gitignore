.vscode/
.DS_Store
Thumbs.db
*.log
chrome-profile/

# Generic patterns
node_modules/
vendor/
.env
.env.local
.env.*.local
dist/
build/
dist-ssr/
cache/

# Backend patterns
backend/vendor/
backend/node_modules/
backend/bootstrap/cache/*
backend/storage/*.key
