backend/.env
backend/.env.backup
backend/.phpunit.result.cache

# Frontend patterns
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/cache/
frontend/.env
frontend/.env.local
frontend/.env.*.local

